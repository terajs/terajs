{
  "name": "@terajs/vite-plugin",
  "version": "1.1.4",
  "description": "Vite plugin for Terajs SFC compilation, route manifest generation, and dev integration.",
  "author": "Terajs Labs",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.d.ts.map"
  ],
  "keywords": [
    "terajs",
    "vite",
    "plugin",
    "sfc",
    "routing",
    "local-first"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@terajs/devtools": "^1.1.4",
    "@terajs/shared": "^1.0.4",
    "@terajs/runtime": "^1.0.4",
    "@terajs/router-manifest": "^1.0.4",
    "@terajs/router": "^1.0.4",
    "@terajs/sfc": "^1.0.4",
    "@terajs/compiler": "^1.0.4"
  },
  "peerDependencies": {
    "vite": "^8.0.0",
    "@terajs/hub-signalr": "^1.0.4",
    "@terajs/hub-socketio": "^1.0.4",
    "@terajs/hub-websockets": "^1.0.4"
  },
  "peerDependenciesMeta": {
    "@terajs/hub-signalr": {
      "optional": true
    },
    "@terajs/hub-socketio": {
      "optional": true
    },
    "@terajs/hub-websockets": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terajs/terajs.git"
  }
}
