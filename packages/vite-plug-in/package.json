{
  "name": "@terajs/vite-plugin",
  "version": "0.0.1",
  "description": "Vite plugin for Terajs SFC compilation, route manifest generation, and dev integration.",
  "author": "Terajs Labs",
  "type": "module",
  "sideEffects": false,

  "files": [
    "dist",
    "README.md",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.d.ts.map"
  ],

  "keywords": [
    "terajs",
    "vite",
    "plugin",
    "sfc",
    "routing",
    "local-first"
  ],

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },

  "dependencies": {
    "@terajs/shared": "*",
    "@terajs/runtime": "*",
    "@terajs/router-manifest": "*",
    "@terajs/router": "*",
    "@terajs/sfc": "*",
    "@terajs/compiler": "*"
  },

  "peerDependencies": {
    "vite": "^8.0.0"
  },

  "publishConfig": {
    "access": "public"
  }
}
