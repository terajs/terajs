{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "types": ["node", "vitest/globals"]
  },

  "include": ["src"],
  "exclude": [
    "dist",
    "src/**/*.spec.ts"
  ],

  "references": [
    { "path": "../shared" },
    { "path": "../runtime" },
    { "path": "../router-manifest" },
    { "path": "../router" },
    { "path": "../sfc" },
    { "path": "../compiler" }
  ]
}
