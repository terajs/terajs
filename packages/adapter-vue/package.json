{
  "name": "@terajs/adapter-vue",
  "version": "1.0.2",
  "description": "Vue interoperability adapter for mounting Terajs components in Vue applications.",
  "author": "Terajs Labs",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.d.ts.map"
  ],
  "keywords": [
    "terajs",
    "vue",
    "adapter",
    "interop",
    "local-first"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@terajs/reactivity": "^1.0.0",
    "@terajs/renderer-web": "^1.0.0",
    "@terajs/runtime": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": "https://github.com/Thecodergabe/terajs"
}
