{
  "name": "@terajs/cli",
  "version": "1.0.5",
  "description": "Official Terajs scaffold and project CLI.",
  "author": "Terajs Labs",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "keywords": [
    "terajs",
    "cli",
    "scaffold",
    "create",
    "vite"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tera": "dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@terajs/vite-plugin": "^1.1.1",
    "commander": "^11.0.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thecodergabe/terajs.git"
  }
}
