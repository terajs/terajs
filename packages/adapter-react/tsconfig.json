{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals", "react", "react-dom"]
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "references": [
    { "path": "../renderer-web" },
    { "path": "../runtime" },
    { "path": "../reactivity" }
  ]
}
