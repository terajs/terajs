{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "paths": {
      "@terajs/compiler": ["../compiler"]
    }
  },
  "include": ["src"],
  "exclude": ["dist"],
  "references": [
    { "path": "../compiler" },
    { "path": "../router" }
  ]
}

