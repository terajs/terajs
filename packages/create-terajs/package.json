{
  "name": "create-terajs",
  "version": "1.0.5",
  "description": "npm create wrapper for scaffolding Terajs projects.",
  "author": "Terajs Labs",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "terajs",
    "create",
    "scaffold",
    "starter",
    "vite"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-terajs": "dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@terajs/cli": "^1.0.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thecodergabe/terajs.git"
  }
}
