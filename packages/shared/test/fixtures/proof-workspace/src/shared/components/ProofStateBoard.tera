<template>
  <section class="proof-state-board">
    <div class="proof-state-board__hero" data-recording-zoom-target>
      <p class="proof-state-board__eyebrow">Shared social feed proof</p>
      <h2 class="proof-state-board__title">One Terajs feed, built for DOM and Android.</h2>
      <p class="proof-state-board__summary">{{ boardSummary() }}</p>
    </div>

    <div class="proof-state-board__controls">
      <button type="button" class="proof-state-board__control" data-action="toggle-queue" @click="toggleQueue()">
        {{ queueVisible() ? 'Hide feed' : 'Show feed' }}
      </button>
      <button type="button" class="proof-state-board__control" data-action="promote-selected" @click="promoteSelected()">
        Pin selected
      </button>
      <button type="button" class="proof-state-board__control" data-action="rotate-queue" @click="rotateQueue()">
        Rotate feed
      </button>
      <div class="proof-state-board__filter">
        <p class="proof-state-board__filter-label">Feed note filter</p>
        <input
          type="text"
          class="proof-state-board__filter-input"
          data-action="host-note-filter"
          placeholder="Filter selected proof note"
          :value="hostNoteFilter()"
          @input="updateHostNoteFilter($event)"
        />
      </div>
    </div>

    <div class="proof-state-board__layout">
      <section class="proof-state-board__feed-panel">
        <div class="proof-state-board__panel-header">
          <p class="proof-state-board__label">Timeline feed</p>
          <p class="proof-state-board__meta">{{ queueMeta() }}</p>
        </div>

        <div v-if="queueVisible()" class="proof-state-board__queue-shell">
          <ul class="proof-state-board__queue" data-queue-list>
            <li
              v-for="story in stories()"
              :key="story.id"
              :data-story-id="story.id"
              class="proof-state-board__queue-item"
            >
              <article :class="storyCardClass(story)">
                <button
                  type="button"
                  class="proof-state-board__story-select"
                  :data-story-target="story.id"
                  :data-story-title="story.title"
                  @click="selectStory(story.id)"
                >
                  <span class="proof-state-board__avatar">{{ story.avatar }}</span>
                  <span class="proof-state-board__post-main">
                    <span class="proof-state-board__post-line">
                      <span class="proof-state-board__story-title">{{ story.name }}</span>
                      <span class="proof-state-board__story-meta">{{ story.handle }} · {{ story.time }}</span>
                    </span>
                    <span class="proof-state-board__post-body">{{ story.title }}</span>
                    <span class="proof-state-board__post-stats">{{ story.comments }} comments · {{ story.likes }} likes</span>
                  </span>
                </button>

                <div class="proof-state-board__actions" aria-label="Post actions">
                  <button type="button" class="proof-state-board__action">Like</button>
                  <button type="button" class="proof-state-board__action">Reply</button>
                  <button type="button" class="proof-state-board__action">Share</button>
                </div>
              </article>
            </li>
          </ul>
        </div>

        <div v-else class="proof-state-board__empty" data-queue-hidden-state>
          Feed hidden while the selected social proof stays mounted for the active host target.
        </div>
      </section>

      <aside class="proof-state-board__side">
        <section class="proof-state-board__composer">
          <p class="proof-state-board__label">Composer</p>
          <h3 class="proof-state-board__composer-title">Record the same feed on both screens.</h3>
          <p class="proof-state-board__composer-copy">
            Build the DOM bundle, build Android artifacts, then scroll this timeline on the phone mirror.
          </p>
        </section>

        <section class="proof-state-board__detail" data-selected-story>
          <div class="proof-state-board__panel-header">
            <p class="proof-state-board__label">Selected proof</p>
            <p class="proof-state-board__meta">{{ selectedSummary() }}</p>
          </div>

          <p class="proof-state-board__detail-host">{{ selectedStory().hostLabel }}</p>
          <h3 class="proof-state-board__detail-title">{{ selectedStory().name }}</h3>
          <p class="proof-state-board__detail-summary">{{ selectedStory().summary }}</p>

          <dl class="proof-state-board__facts">
            <div class="proof-state-board__fact">
              <dt>Target</dt>
              <dd data-selected-host>{{ selectedStory().host }}</dd>
            </div>
            <div class="proof-state-board__fact">
              <dt>Command</dt>
              <dd>{{ selectedStory().command }}</dd>
            </div>
            <div class="proof-state-board__fact">
              <dt>Status</dt>
              <dd>{{ selectedStory().status }}</dd>
            </div>
          </dl>

          <p class="proof-state-board__note-filter" data-note-filter-summary>
            {{ hostNoteFilterSummary() }}
          </p>

          <p v-if="showsSelectedHostNote()" class="proof-state-board__note" data-selected-note>
            {{ selectedHostNote() }}
          </p>
          <p v-else-if="hasSelectedHostNote()" class="proof-state-board__note proof-state-board__note--muted" data-selected-note-filtered>
            {{ filteredHostNoteSummary() }}
          </p>
        </section>
      </aside>
    </div>
  </section>
</template>

<script>
const stories = signal([
  {
    id: 'alpha',
    avatar: 'AL',
    name: 'Ari Lane',
    handle: '@ari',
    time: '2m',
    title: 'The DOM build is live. Same Terajs route, same feed cards, production bundle ready.',
    host: 'web',
    hostLabel: 'Production DOM proof',
    status: 'Ready',
    command: 'npm run build',
    comments: 12,
    likes: 128,
    summary: 'This post anchors the desktop preview moment after the DOM bundle finishes.',
    hostNote: 'DOM proof renders the light social feed from shared .tera source.'
  },
  {
    id: 'bravo',
    avatar: 'ND',
    name: 'Noor Dev',
    handle: '@noor',
    time: '4m',
    title: 'Android artifacts just landed: route manifest, modules, bootstrap commands, live runtime.',
    host: 'android',
    hostLabel: 'Android artifact proof',
    status: 'Ready',
    command: 'tera build --target android',
    comments: 9,
    likes: 96,
    summary: 'This post is the handoff point from shared source to generated Android assets.',
    hostNote: 'Android proof receives command batches while JS owns reconciliation.'
  },
  {
    id: 'charlie',
    avatar: 'MK',
    name: 'Mika Kane',
    handle: '@mika',
    time: '7m',
    title: 'Phone mirror is scrolling through six real posts, not a placeholder splash screen.',
    host: 'android',
    hostLabel: 'Android scroll proof',
    status: 'Recording beat',
    command: 'adb install -r app-debug.apk',
    comments: 18,
    likes: 211,
    summary: 'This post proves Android has enough vertical content for the final scroll shot.',
    hostNote: 'Android scroll depth comes from six shared feed records plus proof cards.'
  },
  {
    id: 'delta',
    avatar: 'JS',
    name: 'Jules Stone',
    handle: '@jules',
    time: '11m',
    title: 'Like, Reply, and Share controls stay in the card so the native view tree has real buttons.',
    host: 'shared',
    hostLabel: 'Interaction proof',
    status: 'Ready',
    command: 'select, like, reply, share',
    comments: 7,
    likes: 74,
    summary: 'This post keeps the feed visually credible while preserving button mapping coverage.',
    hostNote: 'Shared actions render as DOM buttons and native buttons without widening the bridge.'
  },
  {
    id: 'echo',
    avatar: 'TC',
    name: 'Tera Crew',
    handle: '@terajs',
    time: '15m',
    title: 'One source root builds deliberately: DOM first, Android next, iOS source smoke later.',
    host: 'universal',
    hostLabel: 'Universal workflow proof',
    status: 'Ready',
    command: 'tera build --target web,android',
    comments: 22,
    likes: 305,
    summary: 'This post connects the demo to the universal workspace readiness story.',
    hostNote: 'Universal mode stays explicit so the default scaffold remains web-first.'
  },
  {
    id: 'foxtrot',
    avatar: 'SR',
    name: 'Sam Rivera',
    handle: '@sam',
    time: '19m',
    title: 'Final reveal: desktop preview on the left, Android device on the right, same feed copy.',
    host: 'web + android',
    hostLabel: 'Two-screen proof',
    status: 'Ready to record',
    command: 'zoom out',
    comments: 15,
    likes: 184,
    summary: 'This post gives the recording a final side-by-side payoff.',
    hostNote: 'The reveal shows the same shared route on DOM and Android.'
  }
])

const queueVisible = signal(true)
const selectedStoryId = signal('alpha')
const hostNoteFilter = signal('')

function boardSummary() {
  return `${stories().length} posts create real scroll depth while the selected card proves target-specific build output.`
}

function queueMeta() {
  return queueVisible()
    ? `${stories().length} posts ready`
    : 'Feed collapsed'
}

function toggleQueue() {
  queueVisible.set(!queueVisible())
}

function selectStory(id) {
  selectedStoryId.set(id)
}

function selectedStory() {
  return stories().find((story) => story.id === selectedStoryId()) || stories()[0]
}

function selectedSummary() {
  const story = selectedStory()
  return story ? `${story.hostLabel} selected` : 'No feed post selected'
}

function selectedHostNote() {
  const story = selectedStory()
  return story ? story.hostNote : ''
}

function readEventTextValue(event) {
  if (event && typeof event.value === 'string') {
    return event.value
  }

  if (event && typeof event.text === 'string') {
    return event.text
  }

  if (event && event.target && typeof event.target.value === 'string') {
    return event.target.value
  }

  return ''
}

function normalizedHostNoteFilter() {
  return hostNoteFilter().trim().toLowerCase()
}

function updateHostNoteFilter(event) {
  hostNoteFilter.set(readEventTextValue(event))
}

function hasSelectedHostNote() {
  return selectedHostNote().length > 0
}

function hostNoteFilterSummary() {
  const filter = hostNoteFilter().trim()
  return filter.length > 0
    ? `Filtering feed note by "${filter}".`
    : 'Feed note filter inactive.'
}

function showsSelectedHostNote() {
  const note = selectedHostNote()
  if (!note.length) {
    return false
  }

  const filter = normalizedHostNoteFilter()
  return filter.length === 0 || note.toLowerCase().includes(filter)
}

function filteredHostNoteSummary() {
  const filter = hostNoteFilter().trim()
  return filter.length > 0
    ? `Current feed note is hidden until it matches "${filter}".`
    : ''
}

function promoteSelected() {
  const currentId = selectedStoryId()

  stories.update((list) => {
    const index = list.findIndex((story) => story.id === currentId)

    if (index <= 0) {
      return list
    }

    const selected = list[index]
    return [selected, ...list.slice(0, index), ...list.slice(index + 1)]
  })
}

function rotateQueue() {
  stories.update((list) => {
    if (list.length < 2) {
      return list
    }

    return [...list.slice(1), list[0]]
  })
}

function storyCardClass(story) {
  return story.id === selectedStoryId()
    ? 'proof-state-board__post proof-state-board__post--active'
    : 'proof-state-board__post'
}
</script>

<style scoped>
.proof-state-board {
  display: grid;
  gap: 1rem;
  color: #0f172a;
}

.proof-state-board__hero,
.proof-state-board__feed-panel,
.proof-state-board__composer,
.proof-state-board__detail {
  border: 1px solid #dbe3ef;
  border-radius: 1rem;
  background: #ffffff;
  box-shadow: 0 18px 44px rgba(15, 23, 42, 0.08);
}

.proof-state-board__hero {
  display: grid;
  gap: 0.45rem;
  padding: 1.35rem;
}

.proof-state-board__eyebrow,
.proof-state-board__label,
.proof-state-board__filter-label {
  margin: 0;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #2563eb;
}

.proof-state-board__title {
  margin: 0;
  font-size: 2rem;
  line-height: 1.05;
  color: #0f172a;
}

.proof-state-board__summary,
.proof-state-board__meta,
.proof-state-board__composer-copy,
.proof-state-board__detail-summary,
.proof-state-board__note,
.proof-state-board__note-filter,
.proof-state-board__empty {
  margin: 0;
  color: #526070;
  line-height: 1.55;
}

.proof-state-board__controls {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: end;
}

.proof-state-board__control,
.proof-state-board__filter-input,
.proof-state-board__action {
  border: 1px solid #cbd5e1;
  border-radius: 0.8rem;
  background: #ffffff;
  color: #0f172a;
  font: inherit;
}

.proof-state-board__control,
.proof-state-board__action {
  padding: 0.68rem 0.9rem;
  cursor: pointer;
}

.proof-state-board__filter {
  display: grid;
  gap: 0.35rem;
  min-width: min(100%, 18rem);
}

.proof-state-board__filter-input {
  width: 100%;
  padding: 0.72rem 0.85rem;
}

.proof-state-board__layout {
  display: grid;
  gap: 1rem;
}

.proof-state-board__feed-panel,
.proof-state-board__composer,
.proof-state-board__detail {
  padding: 1rem;
}

.proof-state-board__side {
  display: grid;
  gap: 1rem;
  align-content: start;
}

.proof-state-board__panel-header {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 0.5rem;
  align-items: baseline;
}

.proof-state-board__queue {
  display: grid;
  gap: 0.85rem;
  list-style: none;
  margin: 1rem 0 0;
  padding: 0;
}

.proof-state-board__post {
  display: grid;
  gap: 0.8rem;
  padding: 1rem;
  border: 1px solid #e2e8f0;
  border-radius: 0.95rem;
  background: #f8fafc;
}

.proof-state-board__post--active {
  border-color: #60a5fa;
  background: #eff6ff;
}

.proof-state-board__story-select {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 0.75rem;
  width: 100%;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  text-align: left;
  cursor: pointer;
}

.proof-state-board__avatar {
  display: inline-grid;
  width: 2.6rem;
  height: 2.6rem;
  place-items: center;
  border-radius: 999px;
  background: #dbeafe;
  color: #1d4ed8;
  font-weight: 800;
}

.proof-state-board__post-main,
.proof-state-board__post-line {
  display: grid;
  gap: 0.25rem;
}

.proof-state-board__story-title,
.proof-state-board__detail-title,
.proof-state-board__composer-title {
  margin: 0;
  color: #0f172a;
  font-weight: 800;
}

.proof-state-board__story-meta,
.proof-state-board__post-stats,
.proof-state-board__detail-host {
  color: #64748b;
}

