}

.proof-state-board__composer,
.proof-state-board__detail {
  display: grid;
  gap: 0.8rem;
}

.proof-state-board__facts {
  display: grid;
  gap: 0.65rem;
  margin: 0;
}

.proof-state-board__fact {
  display: grid;
  gap: 0.15rem;
}

.proof-state-board__fact dt {
  color: #64748b;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.proof-state-board__fact dd {
  margin: 0;
  color: #0f172a;
  font-weight: 700;
}

.proof-state-board__note--muted {
  color: #94a3b8;
}

@media (min-width: 900px) {
  .proof-state-board__layout {
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
  }
}
</style>
