{
  "name": "@terajs/app",
  "version": "1.1.4",
  "description": "Default app-facing entry package for Terajs.",
  "author": "Terajs Labs",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.d.ts.map"
  ],
  "keywords": [
    "terajs",
    "framework",
    "reactivity",
    "routing",
    "vite"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./devtools": {
      "import": "./dist/devtools.js",
      "types": "./dist/devtools.d.ts",
      "default": "./dist/devtools.js"
    }
  },
  "dependencies": {
    "@terajs/devtools": "^1.1.4",
    "@terajs/reactivity": "^1.0.4",
    "@terajs/renderer-web": "^1.0.4",
    "@terajs/router-manifest": "^1.0.4",
    "@terajs/router": "^1.0.4",
    "@terajs/runtime": "^1.0.4",
    "@terajs/vite-plugin": "^1.1.4"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terajs/terajs.git"
  }
}
