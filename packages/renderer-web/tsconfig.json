{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "jsx": "react-jsx",
    "jsxImportSource": ".",
    
    "paths": {
      "./src/jsx-runtime": ["./src/jsx-runtime.ts"]
    },
    "types": ["node", "vitest/globals"]
  },

  "include": ["src/**/*"],
  "exclude": ["dist"],

  "references": [
    { "path": "../shared" },
    { "path": "../runtime" },
    { "path": "../reactivity" },
    { "path": "../renderer" },
    { "path": "../router" }
  ]
}
