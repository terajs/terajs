    { "path": "./packages/compiler"},
    { "path": "./packages/reactivity" },
    { "path": "./packages/sfc" },
    { "path": "./packages/runtime" },
    { "path": "./packages/renderer" },
    { "path": "./packages/renderer-ssr"},
    { "path": "./packages/renderer-web" },
    { "path": "./packages/router" },
    { "path": "./packages/router-manifest" },
    { "path": "./packages/ui" },
    { "path": "./packages/vite-plug-in" }
  ]
}