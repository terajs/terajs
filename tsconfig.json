{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],

    "paths": {
      "@terajs/*": ["./packages/*/src"]
    }
  },
  "files": [],
  "include": [],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/compiler"},
    { "path": "./packages/reactivity" },
    { "path": "./packages/sfc" },
    { "path": "./packages/runtime" },
    { "path": "./packages/renderer" },
    { "path": "./packages/renderer-ssr"},
    { "path": "./packages/renderer-web" },
    { "path": "./packages/router" },
    { "path": "./packages/router-manifest" },
    { "path": "./packages/ui" },
    { "path": "./packages/terajs" },
    { "path": "./packages/vite-plug-in" },
    { "path": "./packages/cli" },
    { "path": "./packages/adapter-react" },
    { "path": "./packages/adapter-vue" },
    { "path": "./packages/adapter-ai" },
    { "path": "./packages/hub-signalr" },
    { "path": "./packages/hub-socketio" },
    { "path": "./packages/hub-websockets" }
  ]
}