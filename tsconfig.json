{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@terajs/*": ["./packages/*/dist/index.d.ts"]
    }
  },
  "files": [],
  "include": [],
  "references": [
