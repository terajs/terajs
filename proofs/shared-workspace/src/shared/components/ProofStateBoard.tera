<template>
  <section class="proof-state-board">
    <div class="proof-state-board__intro">
      <p class="proof-state-board__eyebrow">Interactive shared-state proof</p>
      <h2 class="proof-state-board__title">One shared route, thin host targets, and stable keyed updates.</h2>
      <p class="proof-state-board__summary">{{ boardSummary() }}</p>
    </div>

    <div class="proof-state-board__controls">
      <button type="button" class="proof-state-board__control" data-action="toggle-queue" @click="toggleQueue()">
        {{ queueVisible() ? 'Hide queue' : 'Show queue' }}
      </button>
      <button type="button" class="proof-state-board__control" data-action="promote-selected" @click="promoteSelected()">
        Promote selected
      </button>
      <button type="button" class="proof-state-board__control" data-action="rotate-queue" @click="rotateQueue()">
        Rotate queue
      </button>
    </div>

    <div class="proof-state-board__layout">
      <section class="proof-state-board__panel">
        <div class="proof-state-board__panel-header">
          <p class="proof-state-board__label">Shared queue</p>
          <p class="proof-state-board__meta">{{ queueMeta() }}</p>
        </div>

        <div v-if="queueVisible()" class="proof-state-board__queue-shell">
          <ul class="proof-state-board__queue" data-queue-list>
            <li
              v-for="story in stories()"
              :key="story.id"
              :data-story-id="story.id"
              class="proof-state-board__queue-item"
            >
              <button
                type="button"
                :class="storyButtonClass(story)"
                :data-story-target="story.id"
                @click="selectStory(story.id)"
              >
                <span class="proof-state-board__story-title">{{ story.title }}</span>
                <span class="proof-state-board__story-meta">{{ story.hostLabel }}</span>
              </button>
            </li>
          </ul>
        </div>

        <div v-else class="proof-state-board__empty" data-queue-hidden-state>
          Queue hidden while the selected proof stays mounted for the active host target.
        </div>
      </section>

      <section class="proof-state-board__panel">
        <div class="proof-state-board__panel-header">
          <p class="proof-state-board__label">Selected slice</p>
          <p class="proof-state-board__meta">{{ selectedSummary() }}</p>
        </div>

        <div v-if="selectedStory()" class="proof-state-board__detail" data-selected-story>
          <p class="proof-state-board__detail-host">{{ selectedStory().hostLabel }}</p>
          <h3 class="proof-state-board__detail-title">{{ selectedStory().title }}</h3>
          <p class="proof-state-board__detail-summary">{{ selectedStory().summary }}</p>

          <dl class="proof-state-board__facts">
            <div class="proof-state-board__fact">
              <dt>Target</dt>
              <dd data-selected-host>{{ selectedStory().host }}</dd>
            </div>
            <div class="proof-state-board__fact">
              <dt>Status</dt>
              <dd>{{ selectedStory().status }}</dd>
            </div>
          </dl>

          <p v-if="hasSelectedHostNote()" class="proof-state-board__note" data-selected-note>
            {{ selectedHostNote() }}
          </p>
        </div>
      </section>
    </div>
  </section>
</template>

<script>
const stories = signal([
  {
    id: 'alpha',
    title: 'Web shell parity',
    host: 'web',
    hostLabel: 'Web host proof',
    status: 'Ready',
    summary: 'The shared route stays renderer-neutral while the web target keeps DOM work on the fast local path.',
    hostNote: 'Web keeps DOM-specific optimizations inside renderer-web instead of widening shared helpers.'
  },
  {
    id: 'bravo',
    title: 'Android command fidelity',
    host: 'android',
    hostLabel: 'Android host proof',
    status: 'Ready',
    summary: 'The same route module drives Android views through host commands, event payloads, and keyed mutations.',
    hostNote: 'Android stays command-oriented so JS owns reconciliation while native owns concrete view mutation.'
  },
  {
    id: 'charlie',
    title: 'iOS bridge readiness',
    host: 'ios',
    hostLabel: 'iOS host proof',
    status: 'Planned locally',
    summary: 'The shared source already reserves the iOS host surface without treating DOM output as the source of truth.',
    hostNote: 'iOS remains a thin UIKit host target, with the bridge carrying commands and event payloads only.'
  }
])

const queueVisible = signal(true)
const selectedStoryId = signal('alpha')

function boardSummary() {
  return `${stories().length} proof slices are driven from shared source while each host target keeps its concrete view layer thin.`
}

function queueMeta() {
  return queueVisible()
    ? `${stories().length} keyed items ready`
    : 'Queue collapsed'
}

function toggleQueue() {
  queueVisible.set(!queueVisible())
}

function selectStory(id) {
  selectedStoryId.set(id)
}

function selectedStory() {
  return stories().find((story) => story.id === selectedStoryId()) || null
}

function selectedSummary() {
  const story = selectedStory()
  return story ? `${story.hostLabel} selected` : 'No proof slice selected'
}

function selectedHostNote() {
  const story = selectedStory()
  return story ? story.hostNote : ''
}

function hasSelectedHostNote() {
  return selectedHostNote().length > 0
}

function promoteSelected() {
  const currentId = selectedStoryId()

  stories.update((list) => {
    const index = list.findIndex((story) => story.id === currentId)

    if (index <= 0) {
      return list
    }

    const selected = list[index]
    return [selected, ...list.slice(0, index), ...list.slice(index + 1)]
  })
}

function rotateQueue() {
  stories.update((list) => {
    if (list.length < 2) {
      return list
    }

    return [...list.slice(1), list[0]]
  })
}

function storyButtonClass(story) {
  return story.id === selectedStoryId()
    ? 'proof-state-board__story proof-state-board__story--active'
    : 'proof-state-board__story'
}
</script>

<style scoped>
