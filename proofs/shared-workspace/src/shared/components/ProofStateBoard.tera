.proof-state-board__label {
  margin: 0;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #67e8f9;
}

.proof-state-board__title,
.proof-state-board__detail-title {
  margin: 0;
  font-size: 1.45rem;
  line-height: 1.1;
  color: #f8fafc;
}

.proof-state-board__summary,
.proof-state-board__detail-summary,
.proof-state-board__note,
.proof-state-board__empty,
.proof-state-board__meta {
  margin: 0;
  color: rgba(226, 232, 240, 0.78);
  line-height: 1.6;
}

.proof-state-board__controls {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.proof-state-board__control,
.proof-state-board__story {
  border: 1px solid rgba(148, 163, 184, 0.2);
  border-radius: 0.9rem;
  background: rgba(15, 23, 42, 0.54);
  color: #f8fafc;
}

.proof-state-board__control {
  padding: 0.7rem 0.95rem;
  font: inherit;
  cursor: pointer;
}

.proof-state-board__layout {
  display: grid;
  gap: 1rem;
}

.proof-state-board__panel {
  display: grid;
  gap: 1rem;
  padding: 1rem;
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 1.2rem;
  background: rgba(15, 23, 42, 0.34);
}

.proof-state-board__panel-header {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.5rem;
}

.proof-state-board__queue {
  display: grid;
  gap: 0.75rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.proof-state-board__story {
  width: 100%;
  display: grid;
  gap: 0.3rem;
  padding: 0.9rem 1rem;
  text-align: left;
  cursor: pointer;
}

.proof-state-board__story--active {
  border-color: rgba(103, 232, 249, 0.45);
  background: rgba(8, 47, 73, 0.5);
}

.proof-state-board__story-title {
  font-weight: 700;
  color: #f8fafc;
}

.proof-state-board__story-meta,
.proof-state-board__detail-host {
  color: #93c5fd;
}

.proof-state-board__detail {
  display: grid;
  gap: 0.8rem;
}

.proof-state-board__detail-host {
  margin: 0;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.proof-state-board__facts {
  display: grid;
  gap: 0.75rem;
  margin: 0;
}

.proof-state-board__fact {
  display: grid;
  gap: 0.15rem;
}

.proof-state-board__fact dt {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(148, 163, 184, 0.84);
}

.proof-state-board__fact dd {
  margin: 0;
