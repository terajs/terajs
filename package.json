{
  "name": "terajs",
  "version": "1.2.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run clean && tsc -b && npm run guard:source-artifacts",
    "bench:browser": "npm --prefix benchmarks run browser:run",
    "bench:browser:compare": "npm --prefix benchmarks run browser:compare",
    "bench:browser:guard": "npm --prefix benchmarks run browser:guard",
    "bench:frameworks": "npm --prefix benchmarks run frameworks",
    "clean": "node scripts/clean-workspace.mjs",
    "changeset": "changeset",
    "test": "vitest",
    "test:renderer-web:focused": "vitest --run packages/renderer-web/src/renderFromIR.spec.ts packages/renderer-web/src/bindings.spec.ts packages/renderer-web/src/dom.spec.ts packages/renderer-web/src/hydrate.spec.ts packages/renderer-web/src/renderFromIRPerfCanary.spec.ts",
    "test:renderer-android:ts": "vitest --run packages/renderer-android/src",
    "test:renderer-ios:ts": "vitest --run packages/renderer-ios/src",
    "test:renderer-android:kotlin": "node scripts/run-android-renderer-tests.mjs",
    "test:universal:native": "vitest --run packages/cli/test/proofWorkspace.spec.ts packages/cli/test/shell.spec.ts packages/cli/test/shellDoctor.spec.ts packages/cli/test/universalConformance.spec.ts packages/cli/test/universalRuntimeConformance.spec.ts packages/renderer-android/src/proofWorkspaceSmoke.spec.ts packages/renderer-ios/src/proofWorkspaceSmoke.spec.ts",
    "test:sanity": "vitest --run packages/renderer-web/src/stressLeak.spec.ts packages/devtools/src/sanity.spec.ts",
    "test:docs": "npm run audit:docs && vitest --run packages/renderer-web/src/webAppFlow.spec.ts packages/renderer-web/src/hydrate.spec.ts",
    "test:local-first": "vitest --run packages/runtime/src/queue/mutationQueue.spec.ts packages/runtime/src/action.spec.ts packages/runtime/src/resource.spec.ts packages/renderer-web/src/form.spec.ts packages/devtools/src/analytics.spec.ts",
    "test:architecture": "vitest --run packages/shared/src/architectureGuardrails.spec.ts packages/shared/src/webBoundaryGuardrails.spec.ts",
    "typecheck": "npm run clean && tsc -b --pretty false",
    "smoke:external": "node scripts/external-smoke.mjs",
    "guard:source-artifacts": "node scripts/guard-source-artifacts.mjs",
    "guard:publish-metadata": "node scripts/guard-publish-metadata.mjs",
    "prepublishOnly": "npm run guard:publish-metadata",
    "audit:docs": "node scripts/audit-docs.mjs",
    "audit:exports": "node scripts/audit-exports.mjs",
    "audit:exports:strict": "node scripts/audit-exports.mjs --strict",
    "rc:check": "npm run typecheck && npm run test:renderer-web:focused && npx vitest run --maxWorkers=1 && npm run smoke:external -- --skip-build && npm run audit:exports:strict && npm run audit:docs && npm run bench:browser:guard",
    "release:status": "changeset status --verbose",
    "version-packages": "changeset version && node scripts/sync-release-version.mjs && npm install --package-lock-only",
    "release:tag": "node scripts/create-release-tag.mjs",
    "release:tag:push": "node scripts/create-release-tag.mjs --push",
    "release:publish": "npm run guard:publish-metadata && npm run build && changeset publish && npm run release:tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.5.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "workspaces": [
    "packages/*"
  ]
}
