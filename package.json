{
  "name": "terajs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run clean && tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:sanity": "vitest --run packages/renderer-web/src/stressLeak.spec.ts packages/devtools/src/sanity.spec.ts",
    "test:docs": "vitest --run packages/renderer-web/src/webAppFlow.spec.ts packages/renderer-web/src/hydrate.spec.ts",
    "test:architecture": "vitest --run packages/shared/src/architectureGuardrails.spec.ts",
    "typecheck": "npm run clean && tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "workspaces": [
    "packages/*"
  ]
}
