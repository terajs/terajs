{
  "name": "terajs-benchmarks",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "browser": "npm run browser:build && npm run browser:serve",
    "browser:build": "vite build --config vite.browser-bench.config.ts",
    "browser:serve": "node scripts/serve-browser-bench.mjs",
    "browser:run": "npm run browser:build && node scripts/browser-bench-guard.mjs run",
    "browser:compare": "node scripts/browser-bench-guard.mjs compare",
    "browser:guard": "npm run browser:build && node scripts/browser-bench-guard.mjs guard",
    "direct-text": "node scripts/benchmark-direct-text.mjs",
    "frameworks": "node scripts/benchmark-frameworks.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vue-vapor/vue": "^3.20240714.0-6608bb3",
    "jsdom": "^29.0.1",
    "lit": "^3.3.1",
    "playwright-core": "^1.54.2",
    "preact": "^10.27.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "solid-js": "^1.9.12",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}